# Public client configuration.
# Values prefixed with NEXT_PUBLIC_ are bundled into browser code at build time.
NEXT_PUBLIC_BACKEND_API_BASE_URL=http://localhost:8080
NEXT_PUBLIC_ACCESS_TOKEN_STORAGE_KEY=accessToken
NEXT_PUBLIC_ACCESS_TOKEN_COOKIE_KEY=accessToken
NEXT_PUBLIC_ACCESS_TOKEN_COOKIE_MAX_AGE_SECONDS=3600

# Server-only integration keys reserved for future server routes.
# Do not prefix secrets with NEXT_PUBLIC_.
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
OPENAI_API_KEY=
